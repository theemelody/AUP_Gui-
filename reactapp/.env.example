# Backend environment variables (reactapp.py)
# Copy to .env and fill in your values.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# CEA executable — default "cea" assumes it is on PATH
# Override if using a virtualenv: CEA_CMD=/home/user/micromamba/envs/cea/bin/cea
CEA_CMD=cea

# CORS — comma-separated allowed origins (defaults to localhost:5173 and :3000)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
